{
  "name": "mt-billing-activator",
  "version": "1.0.0",
  "private": true,
  "description": "Standalone MT-Billing activator — license keys and password-reset codes (vendor tool)",
  "bin": "activator.cjs",
  "scripts": {
    "build:win": "pkg activator.cjs --targets node18-win-x64 --output dist/mt-billing-activator.exe",
    "build:all": "pkg activator.cjs --targets node18-win-x64,node18-linux-x64,node18-macos-x64 --out-path dist"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.3.0"
  },
  "pkg": {
    "assets": [],
    "outputPath": "dist"
  }
}
