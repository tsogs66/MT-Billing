<?xml version="1.0" encoding="utf-8"?>
<!--
  Allows HTTP panel URLs on LAN during testing. Production panels should use HTTPS.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
